FROM ${BASE_IMAGE}

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.11 \
    python3-pip \
    python3-venv \
    git \
    curl \
    wget \
    ca-certificates \
    build-essential \
    openssh-client \
    netcat-openbsd \
    ${EXTRA_PACKAGES} \
    && rm -rf /var/lib/apt/lists/*

# Install Hermes binary
COPY ${HERMES_BIN} /usr/local/bin/hermes
RUN chmod +x /usr/local/bin/hermes

WORKDIR /workspace

CMD ["/bin/bash"]
